TAC {
    designs: [
        Test1 4 {
            int a0 0
        }
    ]
    entry_point: main
    global: []
    subroutines: [
        Test1.constructor {
            return_type: Test1
            parameters: [
                int p0
            ]
            local: [
                Test1 t0
                int   t1
                Test1 t2
            ]
            instructions: [
                b0 {
                    alloc    t0 Test1 4
                    get_attr t1 t0 a0
                    store    t1 10
                    param    4 t0
                    param    4 p0
                    call     t2 Test1.init 2
                    ret      t2
                }
            ]
        }
        Test1.init {
            return_type: Test1
            parameters: [
                Test1 p1
                int   p2
            ]
            local: [
                int t3
            ]
            instructions: [
                b1 {
                    get_attr t3 p1 a0
                    store    t3 p2
                    ret      p1
                }
            ]
        }
        Test1.get_a {
            return_type: int
            parameters: [
                Test1 p3
            ]
            local: [
                int t4
            ]
            instructions: [
                b2 {
                    get_attr t4 p3 a0
                    ret      t4
                }
            ]
        }
        Test1.set_a {
            return_type: void
            parameters: [
                Test1 p4
                int   p5
            ]
            local: [
                int t5
            ]
            instructions: [
                b3 {
                    get_attr t5 p4 a0
                    store   t5 p5
                    ret      void
                }
            ]
        }
        main {
            return_type: int
            parameters: []
            local: [
                Test1 v0
                int   t6
                int   t7
                float v1
                int   v2
            ]
            instructions: [
                b4 {
                    // var Test1 t = Test1(5);
                    param  4 5
                    call   v0 Test1.constructor 1
                    // print(t.get_a());
                    param  4 v0
                    call   t6 Test1.get_a 1
                    param  4 t6
                    call   void print 1
                    // t.set_a(20);
                    param  4 v0
                    param  4 20
                    call   void Test1.set_a 2
                    // print(t.get_a());
                    param  4 v0
                    call   t7 Test1.get_a 1
                    param  4 t7
                    call   void print 1
                    // var float _abc123 = 30.5;
                    assign v1 30.5
                    // var int _def456 = 15;
                    assign v2 15
                    // return 0;
                    ret    0
                }
            ]
        }
    ]
}
